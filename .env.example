# =============================================================================
# Datawatch — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────
DATAWATCH_ENV=development
DATAWATCH_DEBUG=true
DATAWATCH_LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite path (default: ~/.datawatch/datawatch.db)
DATAWATCH_DB_PATH=~/.datawatch/datawatch.db

# ── PostgreSQL Connector ─────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=datawatch
POSTGRES_PASSWORD=changeme
POSTGRES_DB=datawatch

# ── MySQL Connector ──────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=datawatch
MYSQL_PASSWORD=changeme
MYSQL_DB=datawatch

# ── AWS / S3 Connector ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# ── Kafka Connector ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=datawatch-events
KAFKA_GROUP_ID=datawatch-consumer

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Alerting ─────────────────────────────────────────────────────────────────
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_FROM=alerts@example.com
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_TO=team@example.com

ALERT_SLACK_WEBHOOK_URL=
ALERT_WEBHOOK_URL=

# ── Monitoring ───────────────────────────────────────────────────────────────
MONITOR_INTERVAL_SECONDS=300
MONITOR_RETENTION_DAYS=90
